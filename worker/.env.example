# ANPR MQTT Worker — copy to .env and adjust for your environment.

# MQTT broker (raw TCP, not WebSocket — paho-mqtt speaks native MQTT)
MQTT_BROKER=mqtt://127.0.0.1:1883
# MQTT_USERNAME=anpr
# MQTT_PASSWORD=secret
MQTT_CLIENT_ID=anpr_worker

# PHP backend
BACKEND_URL=http://127.0.0.1/anpr_backend

# UVIS-timeout cron sweep frequency (seconds)
TICK_INTERVAL_S=5

# Cache refresh frequency for settings/channels (seconds)
SETTINGS_POLL_S=10
CHANNELS_POLL_S=30

# Skip duplicate plates seen within this window (seconds)
DEDUPE_WINDOW_S=10

# Channel used when an ANPR device SN is NOT mapped to any channel
FALLBACK_CHANNEL=RJ001

# HTTP request timeout (seconds)
HTTP_TIMEOUT_S=10
