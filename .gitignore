# ── Secrets / local config ────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Claude Code local state ───────────────────────────────────────────
.claude/

# ── Node / frontend ───────────────────────────────────────────────────
node_modules/
dist/
build/
.vite/
*.tsbuildinfo

# ── Python / worker ───────────────────────────────────────────────────
